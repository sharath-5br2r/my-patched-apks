{
  "parallel-jobs": 5,
  "enable-module-update": true,
  "eden-pubg": {
    "enabled": true,
    "app-name": "eden",
    "rv-brand": "pubg",
    "build-mode": "apk",
    "cli-source": "MorpheApp/morphe-cli",
    "local-dlurl": "downloads/eden.apk",
    "patches": [
      {
        "source": "MorpheApp/morphe-patches",
        "args": "-OpackageName='com.tencent.ig'",
        "included-patches": "'Change Package Name'"
      }
    ]
  },
  "winlator-pubgvn": {
    "enabled": false,
    "app-name": "winlator",
    "rv-brand": "pubgvn",
    "build-mode": "apk",
    "cli-source": "MorpheApp/morphe-cli",
    "local-dlurl": "downloads/winlator.apk",
    "patches": [
      {
        "source": "MorpheApp/morphe-patches",
        "args": "-OpackageName='com.vng.pubgmobile'",
        "included-patches": "'Change Package Name'"
      }
    ]
  },
  "fcl-cod": {
    "enabled": false,
    "app-name": "fcl",
    "rv-brand": "cod",
    "build-mode": "apk",
    "cli-source": "MorpheApp/morphe-cli",
    "local-dlurl": "downloads/fcl.apk",
    "patches": [
      {
        "source": "MorpheApp/morphe-patches",
        "args": "-OpackageName='com.activision.callofduty.shooter'",
        "included-patches": "'Change Package Name'"
      }
    ]
  },
  "geode-pubgkr": {
    "enabled": false,
    "app-name": "geode",
    "rv-brand": "pubgkr",
    "build-mode": "apk",
    "cli-source": "MorpheApp/morphe-cli",
    "local-dlurl": "downloads/geode.apk",
    "patches": [
      {
        "source": "MorpheApp/morphe-patches",
        "args": "-OpackageName='com.pubg.krmobile'",
        "included-patches": "'Change Package Name'"
      }
    ]
  },
  "levilauncher-unlocked-bgmi": {
    "enabled": false,
    "app-name": "levilauncher-unlocked",
    "rv-brand": "bgmi",
    "build-mode": "apk",
    "cli-source": "MorpheApp/morphe-cli",
    "local-dlurl": "downloads/levilauncher.apk",
    "patches": [
      {
        "source": "MorpheApp/morphe-patches",
        "args": "-OpackageName='com.pubg.imobile'",
        "included-patches": "'Change Package Name'"
      }
    ]
  }
}
