{
  "parallel-jobs": 5,
  "patches-version": "dev",
  "enable-module-update": false,
  "amazon-india": {
    "enabled": false,
    "app-name": "com.amazon.mShop.android.shopping",
    "rv-brand": "none",
    "build-mode": "apk",
    "version": "latest",
    "patches-source": "MorpheApp/morphe-patches",
    "included-patches": "'Change package name'",
    "patcher-args": "-O\"Package name\"=\"com.amazon.mShop.android.shopping\"",
    "cli-source": "MorpheApp/morphe-cli",
    "uptodown-dlurl": "https://amazon-india.en.uptodown.com/android",
    "apkmirror-dlurl": "https://www.apkmirror.com/apk/amazon-mobile-llc/amazon-india-shop-pay/",
    "dpi": "nodpi anydpi auto"
  }
}
